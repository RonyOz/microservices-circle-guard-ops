// ─────────────────────────────────────────────────────────────
// Jenkinsfile.dev  —  CircleGuard ops-repo
//
// Triggered by: app-repo Jenkinsfile on develop branch push
// Environments: dev namespace
// Stages: validate -> lint chart -> deploy -> smoke test
// ─────────────────────────────────────────────────────────────

pipeline {
    agent any

    parameters {
        string(name: 'SERVICE',   defaultValue: '', description: 'e.g. auth-service or circleguard-auth-service')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'e.g. sha-abc1234')
    }

    environment {
        REGISTRY                    = "registry.digitalocean.com/circleguard"
        NAMESPACE                   = "dev"
        CLUSTER_NAME                = "circleguard-k8s"
        KUBECONFIG                  = "${WORKSPACE}/.kube/config"
        DIGITALOCEAN_ACCESS_TOKEN   = credentials('do-api-token')
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
    }

    stages {

        stage('Validate') {
            steps {
                script {
                    if (!params.SERVICE?.trim() || !params.IMAGE_TAG?.trim()) {
                        error("SERVICE and IMAGE_TAG are required.")
                    }
                    env.SVC = params.SERVICE.trim().replaceAll(/^circleguard-/, '')
                    env.TAG = params.IMAGE_TAG.trim()
                    echo "Service: ${env.SVC} | Tag: ${env.TAG} | Env: ${NAMESPACE}"
                }
            }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Refresh kubeconfig') {
            steps {
                sh '''
                    mkdir -p "${WORKSPACE}/.kube"
                    doctl kubernetes cluster kubeconfig save "$CLUSTER_NAME"
                    chmod 600 "${WORKSPACE}/.kube/config"
                '''
            }
        }

        stage('Sync K8s secrets') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'db-credentials',
                                     usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS'),
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SEC')
                ]) {
                    sh """
                        kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                        # Idempotent: apply overwrites existing secret without error
                        kubectl create secret generic ${env.SVC}-secret \\
                            --from-literal=DB_USERNAME="\${DB_USER}" \\
                            --from-literal=DB_PASSWORD="\${DB_PASS}" \\
                            --from-literal=JWT_SECRET="\${JWT_SEC}" \\
                            --namespace=${NAMESPACE} \\
                            --dry-run=client -o yaml | kubectl apply -f -
                    """
                }
            }
        }

        stage('Helm lint') {
            steps {
                sh "helm lint ./services/${env.SVC}/chart"
            }
        }

        stage('Deploy -> dev') {
            steps {
                sh """
                    helm upgrade --install ${env.SVC} ./services/${env.SVC}/chart \\
                        --namespace ${NAMESPACE} \\
                        --create-namespace \\
                        --set image.repository=${REGISTRY}/${env.SVC} \\
                        --set image.tag=${env.TAG} \\
                        --wait --timeout 5m
                """
            }
        }

        stage('Smoke test') {
            steps {
                sh """
                    kubectl rollout status deployment/${env.SVC} \\
                        -n ${NAMESPACE} --timeout=90s
                    kubectl get pods -n ${NAMESPACE} \\
                        -l app.kubernetes.io/name=${env.SVC}
                """
            }
        }
    }

    post {
        failure {
            sh "helm rollback ${env.SVC} --namespace ${NAMESPACE} || true"
            echo "[FAIL] Dev deploy failed - rolled back."
        }
        success {
            echo "[ OK ] ${env.SVC}:${env.TAG} live in dev."
        }
        cleanup { cleanWs() }
    }
}
