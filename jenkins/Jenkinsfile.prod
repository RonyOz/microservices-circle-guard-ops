// ─────────────────────────────────────────────────────────────
// Jenkinsfile.prod  —  CircleGuard ops-repo
//
// Triggered by: app-repo Jenkinsfile on main branch push (GitFlow: release/* merged to main)
// Environments: production namespace
// Stages: validate -> unit tests -> deploy -> verify -> release notes
//
// Release notes: auto-generated from conventional commits
// (feat/fix/chore) since last Git tag using git-cliff.
// ─────────────────────────────────────────────────────────────

pipeline {
    agent any

    parameters {
        string(name: 'SERVICE',    defaultValue: '', description: 'e.g. auth-service')
        string(name: 'IMAGE_TAG',  defaultValue: '', description: 'e.g. sha-abc1234')
        string(name: 'GIT_COMMIT', defaultValue: '', description: 'Full commit SHA from app-repo')
        string(name: 'VERSION',    defaultValue: '', description: 'Semantic version e.g. 1.2.0 (optional)')
    }

    environment {
        REGISTRY                    = "registry.digitalocean.com/circleguard"
        NAMESPACE                   = "production"
        CLUSTER_NAME                = "circleguard-k8s"
        KUBECONFIG                  = "${WORKSPACE}/.kube/config"
        DIGITALOCEAN_ACCESS_TOKEN   = credentials('do-api-token')
        GITHUB_TOKEN                = credentials('github-token')
        APP_REPO                    = "RonyOz/microservices-circle-guard-dev"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '50'))
        timestamps()
    }

    stages {

        stage('Validate') {
            steps {
                script {
                    if (!params.SERVICE?.trim() || !params.IMAGE_TAG?.trim()) {
                        error("SERVICE and IMAGE_TAG are required.")
                    }
                    env.SVC = params.SERVICE.trim().replaceAll(/^circleguard-/, '')
                    env.TAG = params.IMAGE_TAG.trim()
                    echo "Production deploy: ${env.SVC}:${env.TAG}"
                }
            }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Refresh kubeconfig') {
            steps {
                sh '''
                    mkdir -p "${WORKSPACE}/.kube"
                    doctl kubernetes cluster kubeconfig save "$CLUSTER_NAME"
                    chmod 600 "${WORKSPACE}/.kube/config"
                '''
            }
        }

        // ── Unit tests before touching production ────────────────
        // Fast gate: if unit tests fail, we never touch production.
        stage('Unit tests') {
            steps {
                sh """
                    docker run --rm \\
                        ${REGISTRY}/${env.SVC}:${env.TAG} \\
                        sh -c "./gradlew test --tests '*Unit*' || npm test -- --testPathPattern=unit || go test ./... -run Unit"
                """
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: '**/test-results/**/*.xml'
                }
            }
        }

        stage('Helm lint') {
            steps {
                sh "helm lint ./services/${env.SVC}/chart"
            }
        }

        // ── Blue/green-safe deploy ───────────────────────────────
        // helm upgrade with --atomic rolls back automatically on failure.
        stage('Deploy -> production') {
            steps {
                sh """
                    helm upgrade --install ${env.SVC} ./services/${env.SVC}/chart \\
                        --namespace ${NAMESPACE} \\
                        --create-namespace \\
                        --set image.repository=${REGISTRY}/${env.SVC} \\
                        --set image.tag=${env.TAG} \\
                        --atomic \\
                        --timeout 8m
                """
            }
        }

        stage('Verify rollout') {
            steps {
                sh """
                    kubectl rollout status deployment/${env.SVC} \\
                        -n ${NAMESPACE} --timeout=180s
                    kubectl get pods -n ${NAMESPACE} \\
                        -l app.kubernetes.io/name=${env.SVC}
                """
            }
        }

        // ── Release notes ────────────────────────────────────────
        // Uses git-cliff to parse conventional commits and generate
        // a CHANGELOG entry + GitHub Release.
        //
        // Conventional commit format (enforced in app-repo):
        //   feat(auth): add JWT refresh endpoint
        //   fix(kafka): handle consumer group rebalance timeout
        //   chore(deps): bump spring-boot to 3.3.1
        stage('Generate release notes') {
            when {
                expression { params.GIT_COMMIT?.trim() }
            }
            steps {
                script {
                    def version = params.VERSION?.trim() ?: "sha-${env.TAG}"
                    def releaseDate = new Date().format("yyyy-MM-dd")

                    sh """
                        # Install git-cliff if not present
                        if ! command -v git-cliff &> /dev/null; then
                            curl -L https://github.com/orhun/git-cliff/releases/download/v2.4.0/git-cliff-2.4.0-x86_64-unknown-linux-gnu.tar.gz \\
                                | tar -xz --strip-components=1
                            mv git-cliff /usr/local/bin/
                        fi

                        # Clone app-repo to read commit history
                        git clone https://x-access-token:${GITHUB_TOKEN}@github.com/${APP_REPO}.git app-src
                        cd app-src

                        # Generate changelog since last tag
                        git-cliff --latest --strip header \\
                            --output ../RELEASE_NOTES.md

                        cd ..

                        # Prepend service + version header
                        echo "## ${env.SVC} - ${version} (${releaseDate})\\n" | \\
                            cat - RELEASE_NOTES.md > RELEASE_NOTES_FINAL.md

                        cat RELEASE_NOTES_FINAL.md
                    """

                    // Publish as GitHub Release on the app-repo
                    sh """
                        gh release create "${version}-${env.SVC}" \\
                            --repo ${APP_REPO} \\
                            --title "${env.SVC} ${version}" \\
                            --notes-file RELEASE_NOTES_FINAL.md \\
                            --target ${params.GIT_COMMIT} || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'RELEASE_NOTES_FINAL.md',
                                     allowEmptyArchive: true
                }
            }
        }
    }

    post {
        failure {
            echo "[FAIL] Production deploy failed. --atomic ensured automatic rollback."
        }
        success {
            echo "[ OK ] ${env.SVC}:${env.TAG} in production. Release notes published."
        }
        cleanup { cleanWs() }
    }
}
