// ─────────────────────────────────────────────────────────────
// Jenkinsfile.dev  —  CircleGuard ops-repo
//
// Triggered by: app-repo Jenkinsfile on develop branch push
// Environments: dev namespace
// Stages: validate -> lint chart -> deploy -> smoke test
// ─────────────────────────────────────────────────────────────

pipeline {
    agent any

    parameters {
        string(name: 'SERVICE',   defaultValue: '', description: 'e.g. auth-service or circleguard-auth-service')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'e.g. sha-abc1234')
    }

    environment {
        REGISTRY      = "registry.digitalocean.com/circleguard"
        NAMESPACE     = "dev"
        CLUSTER_NAME  = "circleguard-k8s"
        KUBECONFIG    = "${WORKSPACE}/.kube/config"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
    }

    stages {

        stage('Validate') {
            steps {
                script {
                    if (!params.SERVICE?.trim() || !params.IMAGE_TAG?.trim()) {
                        error("SERVICE and IMAGE_TAG are required.")
                    }
                    // Normalize: strip optional 'circleguard-' prefix sent by app-repo
                    env.SVC = params.SERVICE.replaceAll(/^circleguard-/, '')
                    echo "Service: ${env.SVC} | Tag: ${params.IMAGE_TAG} | Env: ${NAMESPACE}"
                }
            }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Refresh kubeconfig') {
            steps {
                withCredentials([string(credentialsId: 'do-api-token', variable: 'DO_TOKEN')]) {
                    sh '''
                        export DIGITALOCEAN_ACCESS_TOKEN="$DO_TOKEN"
                        mkdir -p "${WORKSPACE}/.kube"
                        doctl kubernetes cluster kubeconfig save "$CLUSTER_NAME"
                        chmod 600 "${WORKSPACE}/.kube/config"
                    '''
                }
            }
        }

        stage('Helm lint') {
            steps {
                sh "helm lint ./services/${env.SVC}/chart"
            }
        }

        stage('Deploy -> dev') {
            steps {
                sh """
                    helm upgrade --install ${env.SVC} ./services/${env.SVC}/chart \\
                        --namespace ${NAMESPACE} \\
                        --create-namespace \\
                        --set image.repository=${REGISTRY}/${env.SVC} \\
                        --set image.tag=${params.IMAGE_TAG} \\
                        --wait --timeout 5m
                """
            }
        }

        stage('Smoke test') {
            steps {
                sh """
                    kubectl rollout status deployment/${env.SVC} \\
                        -n ${NAMESPACE} --timeout=90s
                    kubectl get pods -n ${NAMESPACE} \\
                        -l app.kubernetes.io/name=${env.SVC}
                """
            }
        }
    }

    post {
        failure {
            sh "helm rollback ${env.SVC} --namespace ${NAMESPACE} || true"
            echo "[FAIL] Dev deploy failed - rolled back."
        }
        success {
            echo "[ OK ] ${env.SVC}:${params.IMAGE_TAG} live in dev."
        }
        cleanup { cleanWs() }
    }
}
